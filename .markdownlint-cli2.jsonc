{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint-cli2/main/schema/markdownlint-cli2-config-schema.json",
  "config": {
    "default": true,
    "MD009": false,
    "MD012": false,
    "MD013": false,
    "MD022": false,
    "MD031": false,
    "MD032": false,
    "MD036": false,
    "MD040": false
  },
  "globs": [
    "AGENTS.md",
    "README.md",
    "SKILL.md",
    "context/**/*.md"
  ]
}
